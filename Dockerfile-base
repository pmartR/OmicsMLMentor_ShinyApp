## slope 'base' container.  Installs system and R libraries.
## SLOPER base dependencies image.  Installs system libraries, R libraries, and others.
## Top image extends this image and copies the source code for the app

## Must provide a secret file for access to private github repos with the build argument:
## docker build --secret id=github_pat,src=.mysecret ...

# Install latest version of rocker image
FROM rocker/shiny:4.2.0

# Load general use libraries
# Keep gettext-base for MultiProbe
RUN apt-get update && apt-get install -y \
    sudo \
    gettext-base \
    pandoc \
    pandoc-citeproc \
    libssl-dev \
    libcurl4-openssl-dev \
    libcairo2-dev \
    libxt-dev \
    libssh2-1-dev \
    libhiredis-dev \
    libgsl-dev \
    cmake \
    libzmq3-dev \
    libxml2-dev \
    libharfbuzz-dev \
    libfreetype6-dev \
    libpng-dev \
    libtiff5-dev \
    libjpeg-dev \
    libfribidi-dev \
    libcurl3-gnutls \
	  vim python3-venv \
	  automake

USER root

# Keep for MultiProbe, direct to correct url
WORKDIR /srv/shiny-server/slope

# only need this to restore
COPY requirements.txt .

# pre-install renv
ENV RENV_VERSION 1.0.3
ENV RENV_WATCHDOG_ENABLED FALSE

RUN R -e "install.packages('remotes', repos = c(CRAN = 'https://cloud.r-project.org'))"
RUN R -e "options('repos'=c(CRAN = 'https://cloud.r-project.org'));remotes::install_version('renv', version = '${RENV_VERSION}')"
RUN R -e "options(renv.config.connect.timeout = 1000L)"
RUN R -e "options(renv.config.connect.retry = 3L)"

# The following 3 lines are needed to successfully install pmartR.
# Need to set linker flags to install pmartR in linux environment
RUN mkdir $HOME/.R
COPY Makevars-docker .
RUN cp Makevars-docker $HOME/.R/Makevars

# Keep for MultiProbe, local DT use due to issue in download
COPY renv ./renv
COPY renv.lock .

# install all packages listed in renv.lock
RUN R -e 'renv::restore()'

## Keep for MultiProbe AWS
RUN R -e "install.packages('aws.s3')"
RUN R -e "install.packages('aws.ec2metadata')"

# python and requirements
COPY requirements.txt .
RUN python3 -m venv /venv
RUN /venv/bin/pip install --upgrade pip
RUN /venv/bin/pip install -r requirements.txt
